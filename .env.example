GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-embedding-2
GEMINI_OUTPUT_DIMENSIONALITY=1536

# Third-party proxy compatibility:
# x-goog-api-key | bearer | query
GEMINI_AUTH_MODE=x-goog-api-key
GEMINI_API_KEY_HEADER=x-goog-api-key
GEMINI_API_KEY_QUERY_PARAM=key

REPO_BEACON_DEFAULT_PROJECT=
REPO_BEACON_INDEX_DIR=.repo-beacon
REPO_BEACON_MAX_FILE_BYTES=524288
REPO_BEACON_TARGET_CHUNK_CHARS=4000
REPO_BEACON_CHUNK_OVERLAP_CHARS=400
REPO_BEACON_MAX_CHUNKS_PER_FILE=80
REPO_BEACON_EMBEDDING_BATCH_SIZE=16
REPO_BEACON_MAX_EMBEDDING_CHUNKS=256
