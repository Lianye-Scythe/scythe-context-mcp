{
  "name": "scythe-context-mcp",
  "version": "0.1.0",
  "description": "Local MCP context engine for Codex with Gemini Embedding 2 support.",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lianye-Scythe/scythe-context-mcp.git"
  },
  "keywords": [
    "codex",
    "mcp",
    "context-engine",
    "code-search",
    "gemini-embedding",
    "sqlite-vec"
  ],
  "bin": {
    "scythe-context-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "README.en.md",
    "README.zh-CN.md",
    "CHANGELOG.md",
    "LICENSE",
    "docs",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "prepack": "npm run build",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=24.11.0 <27"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.4.2",
    "fast-glob": "^3.3.3",
    "ignore": "^7.0.5",
    "sqlite-vec": "^0.1.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.13.2",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
