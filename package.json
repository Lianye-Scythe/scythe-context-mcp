{
  "name": "scythe-context-mcp",
  "version": "0.1.11",
  "description": "Local MCP context engine for Codex with Gemini Embedding 2 support.",
  "type": "module",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Lianye-Scythe/scythe-context-mcp#readme",
  "bugs": {
    "url": "https://github.com/Lianye-Scythe/scythe-context-mcp/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lianye-Scythe/scythe-context-mcp.git"
  },
  "keywords": [
    "codex",
    "mcp",
    "context-engine",
    "code-search",
    "gemini-embedding",
    "sqlite-vec"
  ],
  "bin": {
    "scythe-context-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "README.en.md",
    "README.zh-CN.md",
    "CHANGELOG.md",
    "LICENSE",
    "benchmarks",
    "docs",
    "scripts/context-benchmark.mjs",
    "scripts/context-benchmark-gate.mjs",
    "scripts/prepare-release.mjs",
    "scripts/release-notes.mjs",
    "scripts/tree-sitter-spike.mjs",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/bin-mode.mjs ensure",
    "bench:context": "node scripts/context-benchmark.mjs",
    "bench:context:compare-rerank": "node scripts/context-benchmark.mjs --compare-rerank",
    "bench:context:compare-rerank:hybrid": "node scripts/context-benchmark.mjs --compare-rerank --include-hybrid",
    "bench:context:compare-response-modes": "node scripts/context-benchmark.mjs --compare-response-modes",
    "bench:context:compare-response-modes:hybrid": "node scripts/context-benchmark.mjs --compare-response-modes --include-hybrid",
    "bench:gate": "npm run build && node scripts/context-benchmark-gate.mjs",
    "bench:gate:hybrid": "npm run build && node scripts/context-benchmark-gate.mjs --include-hybrid",
    "bench:context:hybrid": "node scripts/context-benchmark.mjs --include-hybrid",
    "bench:context:source": "npm run build && node scripts/context-benchmark.mjs",
    "spike:tree-sitter": "npm run build && node scripts/tree-sitter-spike.mjs",
    "dev": "tsx src/index.ts",
    "prepack": "npm run build",
    "release:prepare": "node scripts/prepare-release.mjs",
    "smoke": "node dist/index.js --version && node dist/index.js --help",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify": "npm test && npm run build && node scripts/bin-mode.mjs check && npm run smoke && npm audit --omit=dev && npm pack --dry-run"
  },
  "engines": {
    "node": ">=24.11.0 <27"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.4.2",
    "fast-glob": "^3.3.3",
    "ignore": "^7.0.5",
    "sqlite-vec": "^0.1.9",
    "web-tree-sitter": "^0.26.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.13.2",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
